#!/usr/bin/env bun
/**
 * Insert a new docs/<topic>/ entry into ~/.pi/agent/CONTEXT.md's
 * Folder Structure tree, alphabetically sorted.
 * Usage: insert-docs-entry <topic> <description>
 */

import { readFileSync, writeFileSync } from "node:fs";
import { homedir } from "node:os";
import { join } from "node:path";

const [, , topic, description] = process.argv;

if (!topic || !description) {
  console.error(`Usage: ${process.argv[1]} <topic> <description>`);
  process.exit(1);
}

const path = join(homedir(), ".pi", "agent", "CONTEXT.md");
const lines = readFileSync(path, "utf8").split("\n");

// 1. Find docs/ section boundaries
let docStart = -1;
let docEnd = -1;

for (let i = 0; i < lines.length; i++) {
  if (docStart === -1) {
    if (/^[├└]── docs\//.test(lines[i])) docStart = i;
  } else {
    if (/^[├└]── /.test(lines[i]) && i > docStart) {
      docEnd = i;
      break;
    }
  }
}
if (docEnd === -1) docEnd = lines.length;
if (docStart === -1) {
  console.error("ERROR: docs/ section not found in Folder Structure");
  process.exit(1);
}

// 2. Parse the section: header lines + entry pairs
const section = lines.slice(docStart + 1, docEnd);
const header: string[] = [];
const entries: { name: string; desc: string }[] = [];

let i = 0;
// Collect header lines (before first folder entry)
while (i < section.length) {
  if (/^│   [├└]── .+\/$/.test(section[i])) break;
  header.push(section[i]);
  i++;
}
// Collect entry pairs (dir line + CONTEXT.md line)
while (i < section.length) {
  const m = section[i].match(/^│   [├└]── (.+?)\/\s*(← .*)?$/);
  if (!m) { i++; continue; }
  const name = m[1].trim();
  let desc = "";
  if (i + 1 < section.length) {
    const dm = section[i + 1].match(/← (.+)$/);
    if (dm) desc = dm[1].trim();
  }
  entries.push({ name, desc });
  i += 2;
}

// 3. Insert new entry alphabetically
entries.push({ name: topic, desc: description });
entries.sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));

// 4. Rebuild entry lines
const rebuilt: string[] = [];
entries.forEach(({ name, desc }, idx) => {
  const last = idx === entries.length - 1;
  const branch = last ? "└──" : "├──";
  const indent = last ? "    " : "│   ";
  rebuilt.push(`│   ${branch} ${name}/`);
  rebuilt.push(`│   ${indent}└── CONTEXT.md         ← ${desc}`);
});

// 5. Splice back
const newSection = [lines[docStart], ...header, ...rebuilt];
const newLines = [...lines.slice(0, docStart), ...newSection, ...lines.slice(docEnd)];

writeFileSync(path, newLines.join("\n"), "utf8");
console.log(`Inserted docs/${topic}/ into Folder Structure`);
