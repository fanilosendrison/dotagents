#!/usr/bin/env python3
"""
Insert a new docs/<topic>/ entry into ~/.pi/agent/CONTEXT.md's
Folder Structure tree, alphabetically sorted.
Usage: insert-docs-entry <topic> <description>
"""
import sys, os, re


def find_docs_section(lines):
    """Return (start_idx, end_idx) of the docs/ block in the Folder Structure tree."""
    doc_start = None
    doc_end = None

    for i, line in enumerate(lines):
        if doc_start is None:
            # Match a top-level tree line containing 'docs/'
            if re.match(r'^[├└]── docs/', line):
                doc_start = i
        else:
            # The docs section ends at the next sibling (same indent level as docs/)
            if re.match(r'^[├└]── ', line) and i > doc_start:
                doc_end = i
                break

    if doc_end is None:
        doc_end = len(lines)

    return doc_start, doc_end


def parse_entries(section_lines):
    """
    Parse lines under docs/. Returns (header_lines, entries).
    header_lines: non-entry tree lines at the top (e.g. CONTEXT.md index).
    entries: list of (name, description) tuples.
    """
    header_lines = []
    entries = []
    i = 0

    # Collect header lines (everything before the first folder entry)
    while i < len(section_lines):
        m = re.match(r'^│   [├└]── (.+?)/\s*(← .*)?$', section_lines[i])
        if m:
            break  # first folder entry found
        header_lines.append(section_lines[i])
        i += 1

    # Collect entry pairs
    while i < len(section_lines):
        m = re.match(r'^│   [├└]── (.+?)/\s*(← .*)?$', section_lines[i])
        if not m:
            i += 1
            continue

        name = m.group(1).strip()
        desc = ''

        # Next line should be the CONTEXT.md line
        if i + 1 < len(section_lines):
            desc_match = re.search(r'← (.+)$', section_lines[i + 1])
            if desc_match:
                desc = desc_match.group(1).strip()

        entries.append((name, desc))
        i += 2  # skip both lines

    return header_lines, entries


def rebuild_entries(entries):
    """Rebuild entry lines with correct box-drawing prefixes."""
    out = []
    for idx, (name, desc) in enumerate(entries):
        is_last = (idx == len(entries) - 1)
        branch = '└──' if is_last else '├──'
        indent = '    ' if is_last else '│   '

        out.append(f'│   {branch} {name}/\n')
        out.append(f'│   {indent}└── CONTEXT.md         ← {desc}\n')
    return out


def main():
    if len(sys.argv) != 3:
        print(f'Usage: {sys.argv[0]} <topic> <description>', file=sys.stderr)
        sys.exit(1)

    topic = sys.argv[1]
    description = sys.argv[2]
    path = os.path.expanduser('~/.pi/agent/CONTEXT.md')

    with open(path, 'r') as f:
        lines = f.readlines()

    doc_start, doc_end = find_docs_section(lines)
    if doc_start is None:
        print('ERROR: docs/ section not found in Folder Structure', file=sys.stderr)
        sys.exit(1)

    header_lines, entries = parse_entries(lines[doc_start + 1:doc_end])
    entries.append((topic, description))
    entries.sort(key=lambda x: x[0].lower())

    rebuilt = rebuild_entries(entries)
    new_section = [lines[doc_start]] + header_lines + rebuilt
    new_lines = lines[:doc_start] + new_section + lines[doc_end:]

    with open(path, 'w') as f:
        f.writelines(new_lines)

    print(f'Inserted docs/{topic}/ into Folder Structure')


if __name__ == '__main__':
    main()
