#!/usr/bin/env bun
/**
 * Bootstrap a new harness docs/<topic>/ from a single JSON blob.
 * Reads JSON from stdin. Creates the folder, writes CONTEXT.md,
 * and updates both the docs index and the harness router.
 *
 * stdin JSON:
 * {
 *   "topic":       "my-extension",        // kebab-case folder name
 *   "title":       "My Extension",         // human-readable title
 *   "description": "What it does",         // 6 words max, for router
 *   "action":      "Add / modify X",       // Quick Navigation "Want to..." text
 *   "date":        "2026-06-29",           // YYYY-MM-DD
 *   "content":     "# My Extension\n\n..." // full CONTEXT.md body
 * }
 */

import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
import { homedir } from "node:os";
import { join } from "node:path";

const HARNESS = join(homedir(), ".pi", "agent");
const DOCS_INDEX = join(HARNESS, "docs", "CONTEXT.md");
const ROUTER = join(HARNESS, "CONTEXT.md");

interface Input {
  topic: string;
  title: string;
  description: string;
  action: string;
  date: string;
  content: string;
}

// в”Җв”Җ read stdin в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let raw = "";
for await (const chunk of Bun.stdin.stream()) {
  raw += Buffer.from(chunk).toString();
}
const inp: Input = JSON.parse(raw);
const { topic, title, description, action, date, content } = inp;

// Validate required fields
for (const [key, val] of Object.entries(inp)) {
  if (!val || (typeof val === "string" && !val.trim())) {
    console.error(`ERROR: field "${key}" is required and must not be empty`);
    process.exit(1);
  }
}

// в”Җв”Җ 1. Create folder + write CONTEXT.md в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const docDir = join(HARNESS, "docs", topic);
mkdirSync(docDir, { recursive: true });
writeFileSync(join(docDir, "CONTEXT.md"), content, "utf8");
console.log(`вң“ docs/${topic}/CONTEXT.md`);

// в”Җв”Җ 2. Append to docs/CONTEXT.md index в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let index = readFileSync(DOCS_INDEX, "utf8");
const nums = [...index.matchAll(/### (\d+)\./g)].map(m => parseInt(m[1]));
const next = nums.length > 0 ? Math.max(...nums) + 1 : 1;
const entry = `\n### ${next}. ${title}\n- **Date** : ${date}\n- **Doc** : [\`${topic}/CONTEXT.md\`](${topic}/CONTEXT.md)\n`;
index += entry;
writeFileSync(DOCS_INDEX, index, "utf8");
console.log(`вң“ docs/CONTEXT.md (entry ${next})`);

// в”Җв”Җ 3. Append Quick Navigation row to router в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let router = readFileSync(ROUTER, "utf8");
const qnRow = `| ${action} | \`docs/${topic}/CONTEXT.md\` (${description}) |`;
// Insert before the closing of the Quick Navigation table
// The table ends right before the "## Skills" heading
const skillsIdx = router.indexOf("\n## Skills");
if (skillsIdx !== -1) {
  router = router.slice(0, skillsIdx) + "\n" + qnRow + router.slice(skillsIdx);
} else {
  // fallback: append at end
  router += "\n" + qnRow + "\n";
}
console.log("вң“ Quick Navigation row");

// в”Җв”Җ 4. Insert into Folder Structure tree в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const lines = router.split("\n");

let docStart = -1, docEnd = -1;
for (let i = 0; i < lines.length; i++) {
  if (docStart === -1) {
    if (/^[в”ңв””]в”Җв”Җ docs\//.test(lines[i])) docStart = i;
  } else {
    if (/^[в”ңв””]в”Җв”Җ /.test(lines[i]) && i > docStart) { docEnd = i; break; }
  }
}
if (docEnd === -1) docEnd = lines.length;
if (docStart === -1) {
  console.error("ERROR: docs/ section not found in Folder Structure tree");
  process.exit(1);
}

const section = lines.slice(docStart + 1, docEnd);
const header: string[] = [];
const entries: { name: string; desc: string }[] = [];
let i = 0;
while (i < section.length) {
  if (/^в”Ӯ   [в”ңв””]в”Җв”Җ .+\/$/.test(section[i])) break;
  header.push(section[i]); i++;
}
while (i < section.length) {
  const m = section[i].match(/^в”Ӯ   [в”ңв””]в”Җв”Җ (.+?)\/\s*(вҶҗ .*)?$/);
  if (!m) { i++; continue; }
  const name = m[1].trim();
  let d = "";
  if (i + 1 < section.length) {
    const dm = section[i + 1].match(/вҶҗ (.+)$/);
    if (dm) d = dm[1].trim();
  }
  entries.push({ name, desc: d });
  i += 2;
}

entries.push({ name: topic, desc: description });
entries.sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));

const rebuilt: string[] = [];
entries.forEach(({ name, desc }, idx) => {
  const last = idx === entries.length - 1;
  const branch = last ? "в””в”Җв”Җ" : "в”ңв”Җв”Җ";
  const indent = last ? "    " : "в”Ӯ   ";
  rebuilt.push(`в”Ӯ   ${branch} ${name}/`);
  rebuilt.push(`в”Ӯ   ${indent}в””в”Җв”Җ CONTEXT.md         вҶҗ ${desc}`);
});

const newSection = [lines[docStart], ...header, ...rebuilt];
const newLines = [...lines.slice(0, docStart), ...newSection, ...lines.slice(docEnd)];
writeFileSync(ROUTER, newLines.join("\n"), "utf8");
console.log(`вң“ Folder Structure (docs/${topic}/)`);
console.log("Done.");
