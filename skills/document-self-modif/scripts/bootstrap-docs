#!/usr/bin/env bun
/**
 * Bootstrap a new harness docs/<topic>/ from a single JSON blob.
 * Reads JSON from stdin — see lib.ts Input interface for schema.
 *
 * Thin CLI wrapper over lib.ts pure functions. All logic is
 * in lib.ts; this file only does I/O (read stdin, write files).
 */

import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
import { homedir } from "node:os";
import { join } from "node:path";
import {
  type Input,
  validateInput,
  computeNextIndex,
  formatIndexEntry,
  formatQuickNavRow,
  insertQuickNavRow,
  insertFolderEntry,
} from "./lib";

const HARNESS = join(homedir(), ".pi", "agent");

// ── read stdin ────────────────────────────────────────────────
let raw = "";
for await (const chunk of Bun.stdin.stream()) {
  raw += Buffer.from(chunk).toString();
}

let inp: Input;
try {
  inp = JSON.parse(raw);
} catch {
  console.error("ERROR: invalid JSON on stdin");
  process.exit(1);
}

const err = validateInput(inp);
if (err) {
  console.error(`ERROR: ${err}`);
  process.exit(1);
}

const { topic, title, description, action, date, content } = inp;

// ── 1. Write docs/<topic>.md ─────────────────────────────────
const docFile = join(HARNESS, "docs", `${topic}.md`);
writeFileSync(docFile, content, "utf8");
console.log(`✓ docs/${topic}.md`);

// ── 2. Append to docs/CONTEXT.md index ───────────────────────
const indexPath = join(HARNESS, "docs", "CONTEXT.md");
const indexContent = readFileSync(indexPath, "utf8");
const next = computeNextIndex(indexContent);
writeFileSync(
  indexPath,
  indexContent + formatIndexEntry(next, title, date, topic),
  "utf8",
);
console.log(`✓ docs/CONTEXT.md (entry ${next})`);

// ── 3. Insert Quick Navigation row ──────────────────────────
const routerPath = join(HARNESS, "CONTEXT.md");
const qnRow = formatQuickNavRow(action, topic, description);
const qnUpdated = insertQuickNavRow(readFileSync(routerPath, "utf8"), qnRow);
writeFileSync(routerPath, qnUpdated, "utf8");
console.log("✓ Quick Navigation row");

// ── 4. Insert into Folder Structure tree ─────────────────────
try {
  const fsUpdated = insertFolderEntry(qnUpdated, topic, description);
  writeFileSync(routerPath, fsUpdated, "utf8");
  console.log(`✓ Folder Structure (docs/${topic}.md)`);
} catch (e: any) {
  console.error(`ERROR: ${e.message}`);
  process.exit(1);
}

console.log("Done.");
