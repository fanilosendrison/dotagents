#!/usr/bin/env bun
/**
 * Bootstrap a new enforcer docs/<topic>/ from a single JSON blob.
 * Reads JSON from stdin — see lib.ts Input interface for schema.
 */

import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
import { homedir } from "node:os";
import { join } from "node:path";
import {
  type Input,
  validateInput,
  computeNextIndex,
  formatIndexEntry,
  insertFolderEntry,
} from "./lib";

const HARNESS = join(homedir(), ".agents");

// ── read stdin ────────────────────────────────────────────────
let raw = "";
for await (const chunk of Bun.stdin.stream()) {
  raw += Buffer.from(chunk).toString();
}

let inp: Input;
try {
  inp = JSON.parse(raw);
} catch {
  console.error("ERROR: invalid JSON on stdin");
  process.exit(1);
}

const err = validateInput(inp);
if (err) {
  console.error(`ERROR: ${err}`);
  process.exit(1);
}

const { topic, title, action, date, content, wiring, trigger } = inp;

// ── 1. Write <topic>.md ───────────────────────────────────────
const docPath = join(HARNESS, "docs", `${topic}.md`);
writeFileSync(docPath, content, "utf8");
console.log(`✓ docs/${topic}.md`);

// ── 2. Append to docs/CONTEXT.md index ───────────────────────
const indexPath = join(HARNESS, "docs", "CONTEXT.md");
const indexContent = readFileSync(indexPath, "utf8");
const next = computeNextIndex(indexContent);
writeFileSync(
  indexPath,
  indexContent + formatIndexEntry(next, title, date, topic, wiring, trigger),
  "utf8",
);
console.log(`✓ docs/CONTEXT.md (entry ${next})`);

// ── 3. Insert into Folder Structure tree ─────────────────────
const routerPath = join(HARNESS, "AGENTS.md");
try {
  const routerContent = readFileSync(routerPath, "utf8");
  const fsUpdated = insertFolderEntry(routerContent, topic, action);
  writeFileSync(routerPath, fsUpdated, "utf8");
  console.log(`✓ Folder Structure (docs/${topic}.md)`);
} catch (e: any) {
  console.error(`ERROR: ${e.message}`);
  process.exit(1);
}

console.log("Done.");
