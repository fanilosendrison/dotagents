{
	"name": "git-commits-push-tl",
	"version": "0.2.0",
	"description": "Turnlock-orchestrated skill: discover dirty repos, LLM-generate commit messages, commit & push in parallel.",
	"type": "module",
	"private": true,
	"scripts": {
		"test": "bun test --timeout 60000",
		"test:quick": "bun test --timeout 60000 --ignore 'tests/invariants/i1-secret-scanner.test.ts' --ignore 'tests/invariants/i3-parallel-isolation.test.ts' --ignore 'tests/invariants/i4-stdout-compliance.test.ts'",
		"test:run": "PI_SKILL_STATS_MODE=test bun run src/entrypoints/turnlock-orchestrator.ts",
		"start": "bun run src/entrypoints/turnlock-orchestrator.ts | bun run src/entrypoints/turnlock-to-llm-bridge.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/ tests/"
	},
	"dependencies": {
		"zod": "4.3.6",
		"turnlock": "^0.8.0",
		"@fanilosendrison/llm-runtime": "^0.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "^1.1.0",
		"typescript": "^5.7.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	}
}
